# ----- Choose your provider -----
# "groq"   → free API, fast, needs internet
# "ollama" → fully local, no account needed
LLM_PROVIDER=groq

# ----- Groq (free tier) -----
# Get key at: https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# ----- Ollama (local) -----
# Install: https://ollama.com  →  run: ollama pull llama3
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3
